def load_resumes() -> dict[str, str]:
“”“Load all .txt files from resumes/ folder. Key = filename without extension.”””
RESUMES_DIR.mkdir(exist_ok=True)
resumes = {f.stem: f.read_text(encoding=“utf-8”) for f in RESUMES_DIR.glob(”*.txt”)}
return resumes

def fetch_jd_from_db(job_id: str) -> tuple[str, str, str]:
“”“Returns (label, description, url) for a job ID in your database.”””
conn = get_conn()
row  = conn.execute(
“SELECT company, title, description, url FROM jobs WHERE id = ?”, (job_id,)
).fetchone()
conn.close()
if not row:
print(f”❌ Job ID ‘{job_id}’ not found. Run the scraper first, then check view_jobs.py.”)
sys.exit(1)
label = f”{row[‘company’]} — {row[‘title’]}”
return label, (row[“description”] or “”), row[“url”]

def fetch_jd_from_greenhouse_url(url: str) -> tuple[str, str, str]:
“”“Pull full JD from Greenhouse API using the job URL.”””
m_id   = re.search(r”/jobs/(\d+)”, url)
m_slug = re.search(r”greenhouse.io/([^/]+)/jobs”, url)
if m_id and m_slug:
slug   = m_slug.group(1)
job_id = m_id.group(1)
api    = f”https://boards-api.greenhouse.io/v1/boards/{slug}/jobs/{job_id}”
r      = requests.get(api, timeout=10)
if r.status_code == 200:
d = r.json()
return f”{slug} — {d.get(‘title’,’’)}”, d.get(“content”,””), url
return url, “”, url

# ─────────────────────────────────────────────────────────────────

# API CALL

# ─────────────────────────────────────────────────────────────────

def call_claude(prompt: str, api_key: str) -> dict:
r = requests.post(
API_URL,
headers={
“x-api-key”:         api_key,
“anthropic-version”: “2023-06-01”,
“content-type”:      “application/json”,
},
json={
“model”:      MODEL,
“max_tokens”: 1500,
“messages”:   [{“role”: “user”, “content”: prompt}],
},
timeout=30,
)
if r.status_code != 200:
raise RuntimeError(f”API error {r.status_code}: {r.text[:300]}”)

```
text = r.json()["content"][0]["text"].strip()
# Strip any accidental markdown fences
text = re.sub(r"^```(?:json)?", "", text).rstrip("`").strip()
return json.loads(text)
```

