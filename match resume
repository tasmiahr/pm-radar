def main():
parser = argparse.ArgumentParser(description=“JobRadar — Resume Matcher”)

```
source = parser.add_mutually_exclusive_group(required=True)
source.add_argument("--job-id",  help="Job ID from your DB, e.g. gh_7654321")
source.add_argument("--job-url", help="Direct Greenhouse job URL")
source.add_argument("--jd-file", help="Path to a plain-text file with the job description")

parser.add_argument("--resume",      help="Resume filename without .txt (default: all)")
parser.add_argument("--all-resumes", action="store_true", help="Compare all resumes, rank by score")
parser.add_argument("--api-key",     help="Anthropic API key (or set ANTHROPIC_API_KEY env var)")
args = parser.parse_args()

# API key
api_key = args.api_key or os.environ.get("ANTHROPIC_API_KEY")
if not api_key:
    print("❌ Anthropic API key needed.")
    print("   Set it: export ANTHROPIC_API_KEY=sk-ant-...")
    print("   Or use: --api-key sk-ant-...")
    print("   Get one: https://console.anthropic.com/")
    sys.exit(1)

# Resumes
resumes = load_resumes()
if not resumes:
    print(f"❌ No resumes found in {RESUMES_DIR}")
    print(f"   Create a plain text file: resumes/senior_pm.txt")
    sys.exit(1)

# Job description
job_id = None
if args.job_id:
    job_id = args.job_id
    job_label, jd_text, url = fetch_jd_from_db(args.job_id)
elif args.job_url:
    job_label, jd_text, url = fetch_jd_from_greenhouse_url(args.job_url)
else:
    path      = Path(args.jd_file)
    jd_text   = path.read_text(encoding="utf-8")
    job_label = path.stem
    url       = ""

if not jd_text.strip():
    print("❌ Job description is empty. Check the source.")
    sys.exit(1)

# Which resumes to run
if args.resume:
    if args.resume not in resumes:
        print(f"❌ Resume '{args.resume}' not found. Available: {list(resumes.keys())}")
        sys.exit(1)
    resumes_to_use = {args.resume: resumes[args.resume]}
else:
    resumes_to_use = resumes   # all of them (ranks at the end if >1)

# Run the matcher
results = []
for name, text in resumes_to_use.items():
    print(f"  🔍 Analyzing '{name}'...", flush=True)
    prompt = MATCH_PROMPT.format(
        jd=jd_text[:4000],
        name=name,
        resume=text[:4000],
    )
    try:
        result = call_claude(prompt, api_key)
        results.append((name, result))
    except Exception as e:
        print(f"  ❌ Error on '{name}': {e}")

if not results:
    print("❌ No results returned from API.")
    sys.exit(1)

# Sort by score, best first
results.sort(key=lambda x: x[1].get("score", 0), reverse=True)

for name, result in results:
    display_result(result, job_label, name, url)

# Save best score to DB
if job_id and results:
    best_score = results[0][1].get("score", 0)
    conn = get_conn()
    conn.execute("UPDATE jobs SET match_score = ? WHERE id = ?", (best_score, job_id))
    conn.commit()
    conn.close()
    print(f"  💾 Score {best_score}/100 saved to DB for {job_id}")

if len(results) > 1:
    print(f"\n  🏆 Best resume: '{results[0][0]}' — score {results[0][1].get('score')}/100")
```

if **name** == “**main**”:
main()