def display_result(result: dict, job_label: str, resume_name: str, url: str):
score   = result.get(“score”, 0)
verdict = result.get(“verdict”, “”)

```
bar          = "█" * (score // 10) + "░" * (10 - score // 10)
verdict_icon = {"Strong Apply":"🟢","Apply":"🟡","Apply with Caution":"🟠","Skip":"🔴"}.get(verdict, "⚪")

print(f"\n{'═'*65}")
print(f"  📋 {job_label}")
print(f"  📄 Resume: {resume_name}")
print(f"{'─'*65}")
print(f"  Score  : [{bar}] {score}/100")
print(f"  Verdict: {verdict_icon} {verdict}")
print(f"\n  {result.get('summary','')}")

print(f"\n  ✅ Strengths:")
for s in result.get("strengths", []):
    print(f"     • {s}")

print(f"\n  ⚠️  Gaps:")
for g in result.get("gaps", []):
    sev_icon = {"critical":"🔴","moderate":"🟡","minor":"🟢"}.get(g.get("severity"),"⚪")
    print(f"     {sev_icon} [{g.get('severity','?')}] {g.get('gap','')}")
    print(f"        → {g.get('suggestion','')}")

print(f"\n  ✏️  Tailored Resume Bullets:")
for b in result.get("tailored_bullets", []):
    print(f"     • {b}")

print(f"\n  📬 Cover Letter Angle:")
print(f"     {result.get('cover_letter_angle','')}")

if url:
    print(f"\n  🔗 Apply: {url}")
print(f"{'═'*65}\n")
```

