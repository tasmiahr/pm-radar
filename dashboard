// ────────────────────────────────────────────────
// MODAL
// ────────────────────────────────────────────────
function openModal()  { document.getElementById('modalBackdrop').classList.add('open'); }
function closeModal() { document.getElementById('modalBackdrop').classList.remove('open'); }
function closeModalOutside(e) { if (e.target.id === 'modalBackdrop') closeModal(); }

let activeTab = 'paste';
function switchTab(tab) {
  activeTab = tab;
  document.querySelectorAll('.tab-btn').forEach((b,i) => {
    const tabs = ['paste','file','sample'];
    b.classList.toggle('active', tabs[i] === tab);
  });
  document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
  document.getElementById('tab-' + tab).classList.add('active');
}

function loadFile() {
  const file = document.getElementById('fileInput').files[0];
  if (!file) return;
  const reader = new FileReader();
  reader.onload = e => {
    try {
      const data = JSON.parse(e.target.result);
      ingestJobs(data);
      closeModal();
    } catch { alert('Invalid JSON file.'); }
  };
  reader.readAsText(file);
}

function loadData() {
  if (activeTab === 'sample') {
    ingestJobs(SAMPLE_JOBS);
    closeModal();
    return;
  }
  if (activeTab === 'file') { loadFile(); return; }
  // paste tab
  const raw = document.getElementById('jsonPaste').value.trim();
  if (!raw) { alert('Paste your JSON first.'); return; }
  try {
    const data = JSON.parse(raw);
    ingestJobs(Array.isArray(data) ? data : data.jobs || []);
    closeModal();
  } catch(e) { alert('Invalid JSON: ' + e.message); }
}

// ────────────────────────────────────────────────
// INGEST
// ────────────────────────────────────────────────
function ingestJobs(jobs) {
  ALL_JOBS = jobs;
  updateStats();
  applyFilters();

  const now = new Date().toLocaleString('en-US', { hour:'numeric', minute:'2-digit', hour12:true, month:'short', day:'numeric' });
  document.getElementById('lastRun').innerHTML = `<span class="pulse"></span>Updated ${now}`;
}

// ────────────────────────────────────────────────
// STATS
// ────────────────────────────────────────────────
function updateStats() {
  const jobs = ALL_JOBS;
  document.getElementById('statTotal').textContent   = jobs.length;
  document.getElementById('statFresh').textContent   = jobs.filter(j => (j.hours_old ?? 9999) <= 24).length;
  document.getElementById('statWeek').textContent    = jobs.filter(j => (j.days_old  ?? 9999) <= 7).length;
  document.getElementById('statLegit').textContent   = jobs.filter(j => j.ghost_risk === 'low').length;
  document.getElementById('statMaybe').textContent   = jobs.filter(j => j.ghost_risk === 'medium').length;
  document.getElementById('statGhost').textContent   = jobs.filter(j => j.ghost_risk === 'high').length;
  document.getElementById('statRemote').textContent  = jobs.filter(j => j.remote_ok  == 1).length;
  document.getElementById('statApplied').textContent = jobs.filter(j => j.status === 'applied').length;
}

// ────────────────────────────────────────────────
// FILTERS & SORT
// ────────────────────────────────────────────────
function setChip(el, group) {
  document.getElementById(group + 'Chips').querySelectorAll('.chip').forEach(c => c.classList.remove('active'));
  el.classList.add('active');
  filters[group] = el.dataset.val;
  applyFilters();
}

function applyFilters() {
  const search = document.getElementById('searchInput').value.toLowerCase();
  let rows = ALL_JOBS.filter(j => {
    if (search && !(
      (j.company || '').toLowerCase().includes(search) ||
      (j.title   || '').toLowerCase().includes(search) ||
      (j.location|| '').toLowerCase().includes(search)
    )) return false;

    if (filters.tier  !== 'all' && String(j.tier)       !== filters.tier)  return false;
    if (filters.legit !== 'all' && j.ghost_risk          !== filters.legit) return false;
    if (filters.age   !== 'all' && (j.hours_old ?? 99999) > parseInt(filters.age)) return false;
    return true;
  });

  // sort
  rows = sortRows(rows);

  document.getElementById('resultCount').textContent = rows.length + ' jobs';
  renderTable(rows);
}

function sortBy(col) {
  const ths = document.querySelectorAll('thead th');
  ths.forEach(th => { th.classList.remove('sorted','asc'); });

  if (sortCol === col) sortAsc = !sortAsc;
  else { sortCol = col; sortAsc = col === 'hours_old'; }

  const idx = ['hours_old','company','title','location','ghost_risk','salary','applicants','source','match_score'].indexOf(col);
  if (idx >= 0) {
    ths[idx].classList.add('sorted');
    if (!sortAsc) ths[idx].classList.add('asc');
  }
  applyFilters();
}

function sortRows(rows) {
  return [...rows].sort((a, b) => {
    let va = a[sortCol], vb = b[sortCol];
    if (va == null && vb == null) return 0;
    if (va == null) return 1;
    if (vb == null) return -1;
    if (typeof va === 'string') va = va.toLowerCase();
    if (typeof vb === 'string') vb = vb.toLowerCase();
    if (va < vb) return sortAsc ? -1 : 1;
    if (va > vb) return sortAsc ?  1 : -1;
    return 0;
  });
}

// ────────────────────────────────────────────────
// RENDER
// ────────────────────────────────────────────────
function ageStr(job) {
  const h = job.hours_old, d = job.days_old;
  if (h == null && d == null) return '<span class="age-old">unknown</span>';
  if (h != null && h < 24)   return `<span class="age-fresh">${h}h ago</span>`;
  if (h != null && h < 48)   return `<span class="age-recent">${h}h ago</span>`;
  if (d != null && d <= 3)   return `<span class="age-recent">${d}d ago</span>`;
  return `<span class="age-old">${d ?? Math.round(h/24)}d ago</span>`;
}

function legitBadge(risk, reason) {
  const tip = reason ? ` title="${reason}"` : '';
  if (risk === 'low')    return `<span class="legit-low"${tip}>✅ Legit</span>`;
  if (risk === 'medium') return `<span class="legit-medium"${tip}>⚠️ Maybe</span>`;
  return `<span class="legit-high"${tip}>🚫 Ghost</span>`;
}

function matchCell(score) {
  if (score == null) return `<span class="match-na">— no API</span>`;
  const cls = score >= 70 ? '' : score >= 50 ? 'med' : 'low';
  return `<div class="match-score">
    <div class="match-bar-wrap"><div class="match-bar ${cls}" style="width:${score}%"></div></div>
    <span class="match-num">${score}</span>
  </div>`;
}

function locationCell(job) {
  const loc = job.location || '';
  const badge = job.remote_ok == 1
    ? '<span class="badge-remote">🌐 Remote</span>'
    : job.work_pref === 'hybrid'
      ? '<span class="badge-remote badge-hybrid">🏢 Hybrid</span>'
      : '';
  return `<span>${loc}</span>${badge}`;
}

function sourceBadge(src) {
  return `<span class="source-badge source-${src}">${src}</span>`;
}

function salaryCell(salary) {
  if (!salary) return `<span class="salary-na">—</span>`;
  return `<span class="salary-val">${salary}</span>`;
}

function applicantsCell(n) {
  if (n == null) return `<span class="salary-na">—</span>`;
  return `<span class="applicants-val">${n.toLocaleString()}</span>`;
}

function renderTable(rows) {
  const empty = document.getElementById('emptyState');
  const table = document.getElementById('jobTable');
  const tbody = document.getElementById('jobTbody');

  if (ALL_JOBS.length === 0) {
    empty.style.display = 'block';
    table.style.display = 'none';
    return;
  }

  empty.style.display = 'none';
  table.style.display = 'table';

  tbody.innerHTML = rows.map(j => `
    <tr>
      <td class="td-posted col-posted">${ageStr(j)}<br><span style="color:var(--muted);font-size:10px;font-family:var(--mono)">${j.posted_at || ''}</span></td>
      <td class="td-company col-company">${j.company}</td>
      <td class="td-title col-title" title="${j.title}">${j.title}</td>
      <td class="col-location">${locationCell(j)}</td>
      <td class="col-legit">${legitBadge(j.ghost_risk, j.ghost_reason)}</td>
      <td class="col-salary">${salaryCell(j.salary)}</td>
      <td>${applicantsCell(j.applicants)}</td>
      <td class="col-source">${sourceBadge(j.source)}</td>
      <td class="col-match">${matchCell(j.match_score)}</td>
      <td class="col-apply"><a class="apply-btn" href="${j.url}" target="_blank" title="Open job posting">↗</a></td>
    </tr>
  `).join('');
}

// ────────────────────────────────────────────────
// INIT — auto-fetch dashboard_data.json if served
// ────────────────────────────────────────────────
document.querySelectorAll('thead th')[0].classList.add('sorted');
renderTable([]);

async function autoLoad() {
  // Only attempt fetch when served over http(s) — not file://
  if (!location.protocol.startsWith('http')) return;

  try {
    // Cache-bust so GitHub Pages always serves the latest commit
    const res = await fetch('dashboard_data.json?t=' + Date.now());
    if (!res.ok) return;  // file doesn't exist yet, show empty state

    const data = await res.json();
    const jobs = Array.isArray(data) ? data : (data.jobs || []);
    if (jobs.length === 0) return;

    ingestJobs(jobs);

    // Show last-updated from metadata if present
    if (data.meta) {
      const t = data.meta.exported_at || '';
      const n = data.meta.new_this_run ?? null;
      const badge = n !== null && n > 0
        ? ` <span style="color:var(--green);font-family:var(--mono);font-size:11px">(+${n} new)</span>`
        : '';
      document.getElementById('lastRun').innerHTML =
        `<span class="pulse"></span>Updated ${t}${badge}`;
    }
  } catch (e) {
    // Silently fail — user can still use Load Data button
  }
}

autoLoad();
</script>

