def get_new_jobs(limit=10):
“”“Pull the most recently added jobs from the DB for the notification body.”””
if not DB_PATH.exists():
return []
conn = sqlite3.connect(DB_PATH)
conn.row_factory = sqlite3.Row
rows = conn.execute(”””
SELECT company, title, location, remote_ok, ghost_risk, url, tier, hours_old, days_old
FROM jobs
ORDER BY first_seen DESC
LIMIT ?
“””, (limit,)).fetchall()
conn.close()
return [dict(r) for r in rows]

