def send_email(new_count, total, jobs, dashboard_url):
to_addr   = os.environ.get(“NOTIFY_EMAIL_TO”)
from_addr = os.environ.get(“NOTIFY_EMAIL_FROM”)
password  = os.environ.get(“NOTIFY_EMAIL_PASS”)

```
if not all([to_addr, from_addr, password]):
    print("  ⏭️  Email: skipped (NOTIFY_EMAIL_* secrets not set)")
    return False

msg = MIMEMultipart("alternative")
msg["Subject"] = f"📡 JobRadar — {new_count} new job{'s' if new_count != 1 else ''} found"
msg["From"]    = f"JobRadar <{from_addr}>"
msg["To"]      = to_addr

# Plain text fallback
lines = build_job_lines(jobs)
plain = f"JobRadar — {new_count} new jobs\n\n" + "\n".join(lines) + f"\n\nDashboard: {dashboard_url}"
msg.attach(MIMEText(plain, "plain"))
msg.attach(MIMEText(build_email_html(new_count, total, jobs, dashboard_url), "html"))

try:
    with smtplib.SMTP_SSL("smtp.gmail.com", 465) as s:
        s.login(from_addr, password)
        s.sendmail(from_addr, to_addr, msg.as_string())
    print(f"  ✅ Email sent → {to_addr}")
    return True
except Exception as e:
    print(f"  ❌ Email failed: {e}")
    return False
```

def send_discord(new_count, total, jobs, dashboard_url):
webhook = os.environ.get(“NOTIFY_DISCORD_WEBHOOK”)
if not webhook:
print(”  ⏭️  Discord: skipped (NOTIFY_DISCORD_WEBHOOK not set)”)
return False

```
lines = build_job_lines(jobs[:8])  # Discord embeds cap at reasonable length
body = "\n".join(f"`{l}`" for l in lines)

payload = {
    "username": "JobRadar",
    "avatar_url": "https://raw.githubusercontent.com/github/explore/main/topics/python/python.png",
    "embeds": [{
        "title": f"📡 {new_count} new job{'s' if new_count != 1 else ''} found",
