def build_job_lines(jobs):
“”“Plain text lines for email / Slack.”””
lines = []
for j in jobs:
risk  = {“low”: “✅”, “medium”: “⚠️”, “high”: “🚫”}.get(j.get(“ghost_risk”), “?”)
loc   = j.get(“location”) or (“Remote” if j.get(“remote_ok”) else “—”)
age   = f”{j[‘hours_old’]}h” if j.get(“hours_old”) and j[“hours_old”] < 48   
else f”{j.get(‘days_old’, ‘?’)}d”
lines.append(f”{risk} {j[‘company’]} — {j[‘title’]}  [{loc}]  ({age} ago)”)
return lines

