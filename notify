def notify(new_count, total, dashboard_url):
if new_count == 0:
print(”  ℹ️  No new jobs — skipping notifications”)
return

```
print(f"\n🔔 Sending notifications ({new_count} new jobs)...")
jobs = get_new_jobs(limit=10)

sent = 0
sent += send_email(new_count, total, jobs, dashboard_url)
sent += send_discord(new_count, total, jobs, dashboard_url)
sent += send_slack(new_count, total, jobs, dashboard_url)

if sent == 0:
    print("\n  ℹ️  No notification channels configured.")
    print("  Add any of these to GitHub Secrets to enable alerts:")
    print("    NOTIFY_EMAIL_TO + NOTIFY_EMAIL_FROM + NOTIFY_EMAIL_PASS")
    print("    NOTIFY_DISCORD_WEBHOOK")
    print("    NOTIFY_SLACK_WEBHOOK")
